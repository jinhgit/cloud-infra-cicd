# ===================================================
# Terraform 변수 예제 — 기본은 무료 모드
#
#  cp terraform.tfvars.example terraform.tfvars
#  보안: terraform.tfvars 는 Git 커밋 금지
# ===================================================

aws_region   = "ap-northeast-2"
environment  = "dev"
project_name = "cloud-infra"

vpc_cidr                 = "10.0.0.0/16"
public_subnet_cidrs      = ["10.0.1.0/24", "10.0.2.0/24"]
private_web_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]
private_db_subnet_cidrs  = ["10.0.20.0/24", "10.0.21.0/24"]

my_ip = "YOUR_PUBLIC_IP/32"

tags = {
  Owner       = "YOUR_NAME"
  Application = "CloudInfra"
}

# ===================================================
# ★ 무료 모드 (기본) — 그대로 두세요
# ===================================================
acknowledge_paid_aws = false
confirm_paid_apply   = ""
nat_gateway_count    = 0
enable_bastion       = false
enable_eks           = false
enable_ecr           = false

# ===================================================
# 유료 데모 — 사용자 동의 후에만 (끝나면 destroy)
# 권장: ./scripts/terraform-apply-paid.sh
# ===================================================
# acknowledge_paid_aws = true
# confirm_paid_apply   = "YES_I_ACCEPT_AWS_CHARGES"
# nat_gateway_count    = 2
# enable_bastion       = true
# bastion_key_name     = "cloud-infra-bastion"
# enable_eks           = true
# eks_cluster_version  = "1.32"
# eks_node_instance_type = "t3.small"
