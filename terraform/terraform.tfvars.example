# ===================================================
# Terraform 변수값 예제
# 
# 사용법:
# 1. 이 파일을 terraform.tfvars로 복사
# 2. 본인의 환경에 맞게 값 수정
# 3. terraform plan/apply 실행
#
# 보안: terraform.tfvars는 .gitignore에 포함됨
#      절대 GitHub에 커밋하지 말 것!
# ===================================================

# AWS 리전
aws_region = "ap-northeast-2"

# 프로젝트 메타데이터
environment  = "dev"
project_name = "cloud-infra"

# ===================================================
# VPC 및 네트워크 CIDR 설정
# ===================================================

# VPC CIDR 블록 (10.0.0.0/16)
vpc_cidr = "10.0.0.0/16"

# Public 서브넷 (인터넷 접속 가능, ALB/Bastion 호스트 배치)
# AZ-A: 10.0.1.0/24, AZ-C: 10.0.2.0/24
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

# Private Web 서브넷 (웹 서버 배치, NAT Gateway 통해 아웃바운드만)
# AZ-A: 10.0.10.0/24, AZ-C: 10.0.11.0/24
private_web_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

# Private DB 서브넷 (데이터베이스 배치, VPC 내부 통신만)
# AZ-A: 10.0.20.0/24, AZ-C: 10.0.21.0/24
private_db_subnet_cidrs = ["10.0.20.0/24", "10.0.21.0/24"]

# ===================================================
# 보안 설정: Bastion Host SSH 접속 허용 IP
# ===================================================

# 본인의 공인 IP 주소를 아래에 입력
# 예: "203.0.113.42/32" (개별 IP)
#     "203.0.113.0/24"  (대역)
#
# 🔴 중요: 반드시 /32 (개별) 또는 /24 (소수 대역)로 설정
#         0.0.0.0/0 (전체 공개)는 보안 위험!
#
# 공인 IP 확인: https://www.whatismyipaddress.com
my_ip = "YOUR_PUBLIC_IP/32"

# ===================================================
# 추가 태그 (선택사항)
# ===================================================

tags = {
  Owner       = "YOUR_NAME"
  CostCenter  = "YOUR_DEPT"
  Application = "CloudInfra"
}
